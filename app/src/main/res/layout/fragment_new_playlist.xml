<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/NewPlayListScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".newplaylist.ui.NewPlayListFragment">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/firstLeftBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="16dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/firstRightBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="16dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/leftBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="24dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/rightBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="387dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small"
            android:background="?attr/colorSecondary"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/back_from_new_playlist_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/Back_from_screen_button"
                app:srcCompat="@drawable/ic_back_arrow_24" />

            <TextView
                android:id="@+id/ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:fontFamily="@font/ys_display_medium"
                android:gravity="center_vertical"
                android:letterSpacing="0"
                android:paddingStart="12dp"
                android:text="@string/New_playlist"
                android:textColor="?attr/colorOnSecondary"
                android:textSize="22sp" />
        </LinearLayout>

    <ImageView
        android:id="@+id/PlaylistArtwork"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="82dp"
        android:background="@drawable/rounded_dashed_border"
        android:contentDescription="@string/Playlist_artwork"
        android:scaleType="fitXY"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/rightBorder"
        app:layout_constraintStart_toEndOf="@+id/leftBorder"
        app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/inputPlaylistName"
            style="@style/Black_White_Text16sp_medium"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/input_border"
            android:focusableInTouchMode="true"
            android:hint="@string/Playlist_name"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:lines="1"
            android:maxLength="50"
            android:paddingStart="16dp"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:textColorHint="@color/Black_white_color"
            android:textCursorDrawable="@drawable/ic_cursor"
            app:layout_constraintEnd_toStartOf="@+id/firstRightBorder"
            app:layout_constraintStart_toEndOf="@+id/firstLeftBorder"
            app:layout_constraintTop_toBottomOf="@+id/PlaylistArtwork" />

        <TextView
            android:id="@+id/PlaylistNameHint"
            android:layout_width="60dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="-8dp"
            android:background="?attr/colorSecondary"
            android:fontFamily="@font/ys_display_medium"
            android:letterSpacing="0"
            android:text="@string/Playlist_name"
            android:textColor="@color/gray_white_border"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/inputPlaylistName"
            app:layout_constraintTop_toTopOf="@+id/inputPlaylistName"
            tools:visibility="visible" />

        <EditText
            android:id="@+id/inputPlaylistDescription"
            style="@style/Black_White_Text16sp_medium"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/input_border"
            android:focusableInTouchMode="true"
            android:hint="@string/Playlist_description"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:lines="1"
            android:maxLength="50"
            android:paddingStart="16dp"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:textColorHint="@color/Black_white_color"
            android:textCursorDrawable="@drawable/ic_cursor"
            app:layout_constraintEnd_toStartOf="@+id/firstRightBorder"
            app:layout_constraintStart_toEndOf="@+id/firstLeftBorder"
            app:layout_constraintTag="PlaylistDescription"
            app:layout_constraintTop_toBottomOf="@+id/inputPlaylistName" />

        <TextView
            android:id="@+id/PlaylistDescriptionHint"
            android:layout_width="60dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="-8dp"
            android:background="?attr/colorSecondary"
            android:fontFamily="@font/ys_display_medium"
            android:letterSpacing="0"
            android:text="@string/Playlist_description"
            android:textColor="@color/gray_white_border"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/inputPlaylistDescription"
            app:layout_constraintTop_toTopOf="@+id/inputPlaylistDescription"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/buttonBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_tags="PlaylistDescription" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/create_Playlist_button"
            style="@style/White_Text16sp_medium"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/tap_selector"
            android:enabled="false"
            android:text="@string/Playlist_create"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/firstRightBorder"
            app:layout_constraintStart_toEndOf="@+id/firstLeftBorder" />
    </androidx.constraintlayout.widget.ConstraintLayout>



