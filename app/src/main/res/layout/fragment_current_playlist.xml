<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/CurrentPlaylistScreen"
    tools:context=".playlist.ui.PlayListFragment"
    android:background="@color/YP_Light_Gray">

    <View android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>
    
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="360dp">
        <ImageButton
            android:id="@+id/back_from_playlist_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small"
            android:background="@android:color/transparent"
            android:contentDescription="@string/Back_from_screen_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back_arrow_24"/>

        <ImageView
            android:id="@+id/PlaylistArtwork"
            android:layout_width="312dp"
            android:layout_height="312dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_gravity="center"
            android:src="@drawable/img_placeholder_312"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="1:1"
            android:contentDescription="@string/Track_Artwork"/>
    </FrameLayout>

    <TextView
        android:id="@+id/Playlist_Name"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginTop="384dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        style="@style/Black_Text24sp_bold"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="Biiig coool playlist with fresh new tracks"/>

    <TextView
        android:id="@+id/Playlist_Description"
        android:layout_width="wrap_content"
        android:layout_height="21dp"
        android:layout_marginTop="420dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        style="@style/Black_Text18sp_medium"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="This playlist contains many fresh and cool tracks. All of them collected with care from best world charts"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="21dp"
        android:layout_marginTop="449dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/Summary_Length"
            android:layout_gravity="bottom|start"
            android:layout_height="match_parent"
            android:layout_width="0dp"
            android:layout_weight="1"
            style="@style/Black_Text18sp_medium"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            tools:text="9999 минут"/>
        <ImageView
            android:layout_width="13dp"
            android:layout_height="21dp"
            android:src="@drawable/ic_black_dot_separator"
            android:scaleType="centerCrop"/>
        <TextView
            android:id="@+id/Tracks_Amount"
            style="@style/Black_Text18sp_medium"
            android:layout_gravity="bottom|start"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text=""
            tools:text="999 треков"/>
    </LinearLayout>
    
    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:id="@+id/share_playlist"
        android:src="@drawable/ic_share_this_black_24"
        android:layout_marginTop="486dp"
        android:layout_marginStart="16dp"
        android:clickable="true"/>

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:id="@+id/playlist_options"
        android:src="@drawable/ic_vertical_dots_24"
        android:layout_marginTop="486dp"
        android:layout_marginStart="56dp"
        android:clickable="true"/>

    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/top_rounded"
        android:orientation="vertical"
        app:behavior_peekHeight="266dp"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/bottom_sheet_mark" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tracksInPlaylist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/YP_Black"
            android:textAlignment="viewStart"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>