<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/addToPlayListFrame"
    android:layout_height="61dp"
    android:layout_width="match_parent">

    <ImageView
        android:id="@+id/addToPlayListCover"
        android:layout_width="45dp"
        android:layout_height="45dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="13dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/placeholder"
        android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/addToPlayListName"
            android:layout_gravity="top|start"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="66dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="14dp"
            android:layout_height="19dp"
            android:layout_width="match_parent"
            style="@style/TextView16sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="BIG_COOL_PLAylist_with_really_many_good_tracks!"/>
    <TextView
        android:id="@+id/addToPlayListSongsAmount"
        android:layout_gravity="center|start"
        android:layout_height="13dp"
        android:layout_width="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="66dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="34dp"
        android:layout_weight="1"
        style="@style/GreyText11sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="1 000 000"/>

</androidx.constraintlayout.widget.ConstraintLayout>