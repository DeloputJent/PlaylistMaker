<?xml version="1.0" encoding="utf-8"?>
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playListFrame"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="?attr/colorSecondary"
    android:orientation="vertical">
        <ImageView
            android:id="@+id/playlistArtwork"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:scaleType="fitXY"
            android:background="@drawable/background_rounded_border_eight"
            android:src="@drawable/placeholder"/>
        <TextView
            android:id="@+id/playlistName"
            android:layout_gravity="center_vertical|start"
            android:layout_marginTop="4dp"
            android:layout_width="160dp"
            android:layout_height="16dp"
            style="@style/Black_White_Text12sp_medium"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="New PlayList there! Look how cool is it!"/>
        <TextView
            android:id="@+id/tracksInPlaylist"
            android:layout_gravity="center_vertical|start"
            android:layout_width="160dp"
            android:layout_height="16dp"
            style="@style/Black_White_Text12sp_medium"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="1 000 000"/>
    </LinearLayout>