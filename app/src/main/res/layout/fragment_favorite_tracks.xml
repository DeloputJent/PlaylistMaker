<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoriteTracksList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/YP_Black"
        android:textAlignment="viewStart"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="248dp"
        android:indeterminateTint="@color/YP_Blue"
        android:visibility="gone"
        tools:visibility="visible"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/noFavoriteTracksMessage"
        android:visibility="visible">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="106dp"
            android:scaleType="center"
            android:src="@drawable/ic_nothing_found_120"
            android:contentDescription="@string/nothing_found"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="242dp"
            android:fontFamily="@font/ys_display_medium"
            android:letterSpacing="0"
            android:text="@string/Your_media_library_is_empty"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSecondary"
            android:textSize="19sp"/>
    </FrameLayout>
</FrameLayout>